# FUSION IMS — Environment Configuration
# Copy this file to .env and fill in your values

# ── SERVER ──────────────────────────────────────────────
PORT=3000

# ── SECURITY ────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
JWT_SECRET=fusion-ims-change-this-secret-key-2025

# ── AI CONFIGURATION ────────────────────────────────────
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ── CLOUD SYNC (optional) ───────────────────────────────
# Set these if you want cloud backup/sync
# CLOUD_SYNC_URL=https://your-cloud-server.com
# CLOUD_SYNC_KEY=your-sync-key

# ── DEPLOYMENT MODE ─────────────────────────────────────
# Options: local | cloud | hybrid
NODE_ENV=production

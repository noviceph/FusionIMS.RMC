{
  "name": "fusion-ims-server",
  "version": "2.0.0",
  "description": "FUSION IMS — AI-Driven Industrial Management System Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "install-pm2": "npm install -g pm2",
    "start-pm2": "pm2 start server.js --name fusion-ims --watch",
    "stop-pm2": "pm2 stop fusion-ims",
    "restart-pm2": "pm2 restart fusion-ims",
    "logs-pm2": "pm2 logs fusion-ims"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["industrial","automation","plc","dcs","ims","philippines","instrumentation"],
  "author": "FUSION Systems",
  "license": "MIT"
}
